#!/bin/sh

sign=1

signBinary() (
  binaryName="$1"
  compressedName="${binaryName}.zip"

  if [ "$sign" -eq 1 ]; then
    codesign -v -f --timestamp --options=runtime --sign="$CODESIGN_TEAM_ID" "$binaryName"
    zip "$compressedName" "$binaryName"
    rm "$binaryName"
    xcrun notarytool submit --apple-id="$CODESIGN_APPLE_ID" --team-id="$CODESIGN_TEAM_ID" --password="$CODESIGN_PASSWD" "$compressedName"
    unzip "$compressedName"
    rm "$compressedName"
  fi
)

buildPolyNode() {
  polynArch="$1"
  polynSuffix="${2:-$1}"
  baseDir="./PolyNode-darwin-${polynSuffix}"
  polyNodeDir="${baseDir}/PolyNode"
  uninstallDir="${polyNodeDir}/uninstall"

  env GOOS=darwin GOARCH="${polynArch}" go build -ldflags="-s -w" -tags=prod -o polyn ./cmd/polyn

  signBinary polyn

  (
    cd install || exit
    env GOOS=darwin GOARCH="${polynArch}" go build -ldflags="-s -w" -o ../setup ./cmd/setup
  )

  signBinary setup

  (
    cd uninstall || exit
    env GOOS=darwin GOARCH="${polynArch}" go build -ldflags="-s -w" -o "../uninstall-${polynSuffix}"
  )

  signBinary "uninstall-${polynSuffix}"

  mkdir -p "$uninstallDir"

  mv setup "${baseDir}/setup"
  mv polyn "${polyNodeDir}/polyn"
  mv "uninstall-${polynSuffix}" "${uninstallDir}/uninstall"

  cp README.md LICENSE SECURITY.md "$polyNodeDir"

  tar -czf "${baseDir}.tar.gz" "$baseDir"

  rm -rf "$baseDir"
}

buildPolyNode arm64
buildPolyNode amd64 x64
